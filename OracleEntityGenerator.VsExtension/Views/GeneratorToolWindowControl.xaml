<UserControl x:Class="OracleEntityGenerator.VsExtension.Views.GeneratorToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:vm="clr-namespace:OracleEntityGenerator.VsExtension.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:GeneratorToolWindowViewModel}"
             d:DesignHeight="760"
             d:DesignWidth="1040"
             Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
             Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>

        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxItemTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxPopupBackgroundGradientBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxPopupBorderBrushKey}}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxItemMouseOverTextBrushKey}}" />
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxItemMouseOverBackgroundBrushKey}}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxItemMouseOverBorderBrushKey}}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxMouseDownTextBrushKey}}" />
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxSelectionBrushKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ButtonTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.SystemButtonFaceBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="RowBackground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.GridLineBrushKey}}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.GridLineBrushKey}}" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.GridHeadingTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.GridHeadingBackgroundBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.GridLineBrushKey}}" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.GridLineBrushKey}}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="12"
          Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Connection" FontWeight="SemiBold" />
                <UniformGrid Columns="2" Margin="0,6,0,0">
                    <TextBlock Text="Host" VerticalAlignment="Center" />
                    <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Port" VerticalAlignment="Center" />
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Service" VerticalAlignment="Center" />
                    <TextBox Text="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="User" VerticalAlignment="Center" />
                    <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Password" VerticalAlignment="Center" />
                    <PasswordBox x:Name="PasswordInput"
                                 PasswordChanged="PasswordBox_OnPasswordChanged" />
                </UniformGrid>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                <TextBlock Text="Full connection string" FontWeight="SemiBold" />
                <TextBox Height="78"
                         Margin="0,6,0,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding FullConnectionString, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Show system schemas"
                          IsChecked="{Binding ShowSystemSchemas}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                <TextBlock Text="Schema" FontWeight="SemiBold" />
                <ComboBox Margin="0,6,0,0"
                          ItemsSource="{Binding Schemas}"
                          SelectedItem="{Binding SelectedSchemaName}" />
                <Button Margin="0,8,0,0"
                        Content="Load Tables"
                        Command="{Binding LoadTablesCommand}" />
            </StackPanel>

            <StackPanel Grid.Column="3" VerticalAlignment="Bottom" MinWidth="130">
                <Button Content="Test Connection"
                        Command="{Binding TestConnectionCommand}" />
                <Button Margin="0,8,0,0"
                        Content="Load Schemas"
                        Command="{Binding LoadSchemasCommand}" />
                <Button Margin="0,8,0,0"
                        Content="Save Settings"
                        Command="{Binding SaveSettingsCommand}" />
                <Button Margin="0,8,0,0"
                        Content="Load Settings"
                        Command="{Binding LoadSettingsCommand}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Tables"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBox DockPanel.Dock="Right"
                             Width="260"
                             Text="{Binding TableSearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock DockPanel.Dock="Right"
                               Margin="0,0,8,0"
                               Text="Filter"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </DockPanel>

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          ItemsSource="{Binding VisibleTables}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Schema"
                                            Binding="{Binding SchemaName, Mode=OneWay}"
                                            IsReadOnly="True"
                                            Width="120" />
                        <DataGridTextColumn Header="Table"
                                            Binding="{Binding TableName, Mode=OneWay}"
                                            IsReadOnly="True"
                                            Width="*" />
                        <DataGridTextColumn Header="Columns"
                                            Binding="{Binding ColumnCount, Mode=OneWay}"
                                            IsReadOnly="True"
                                            Width="80" />
                        <DataGridCheckBoxColumn Header="PK"
                                                Binding="{Binding HasPrimaryKey, Mode=OneWay}"
                                                IsReadOnly="True"
                                                Width="50" />
                        <DataGridTextColumn Header="Comment"
                                            Binding="{Binding Comment, Mode=OneWay}"
                                            IsReadOnly="True"
                                            Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Generation" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0" Text="Output folder" />
                    <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,8,0,0" Text="Entity namespace" />
                    <TextBox Text="{Binding EntityNamespace, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,8,0,0" Text="Configuration namespace" />
                    <TextBox Text="{Binding ConfigurationNamespace, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,8,0,0" Text="Entity relative folder" />
                    <TextBox Text="{Binding EntityOutputDirectory, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,8,0,0" Text="Configuration relative folder" />
                    <TextBox Text="{Binding ConfigurationOutputDirectory, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,8,0,0" Text="Table prefixes to remove" />
                    <TextBox Text="{Binding TablePrefixesToRemove, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,8,0,0" Text="Column prefixes to remove" />
                    <TextBox Text="{Binding ColumnPrefixesToRemove, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,12,0,0" Text="File header" />
                    <TextBox Height="72"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding FileHeader, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,8,0,0" Text="Entity usings" />
                    <TextBox Text="{Binding EntityUsings, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,8,0,0" Text="Configuration usings" />
                    <TextBox Text="{Binding ConfigurationUsings, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Margin="0,12,0,0"
                              Content="Overwrite existing files"
                              IsChecked="{Binding OverwriteExistingFiles}" />
                    <CheckBox Margin="0,6,0,0"
                              Content="Nullable reference types"
                              IsChecked="{Binding NullableReferenceTypes}" />
                    <CheckBox Margin="0,6,0,0"
                              Content="Generate XML comments"
                              IsChecked="{Binding GenerateXmlComments}" />
                    <CheckBox Margin="0,6,0,0"
                              Content="Allow keyless entities"
                              IsChecked="{Binding GenerateKeylessEntities}" />

                    <Button Margin="0,16,0,0"
                            Height="34"
                            Content="Generate"
                            Command="{Binding GenerateCommand}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="100" />
            </Grid.RowDefinitions>
            <TextBlock Text="Log" FontWeight="SemiBold" />
            <TextBox Grid.Row="1"
                     Margin="0,6,0,0"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding LogText}" />
        </Grid>
    </Grid>
</UserControl>
